@model IEnumerable<CalkosManager.Domain.Entities.ProspettoCobral>

@{
    /*
     * VIEW: Lista Ordini COBRAL
     *
     * Questa pagina mostra:
     * - tutti gli ordini COBRAL
     * - oppure solo quelli relativi a un file importato (idFileImportato)
     *
     * La lista è popolata dal controller ProspettiCobralController.
     */
    ViewData["Title"] = "Lista Ordini COBRAL";
}

@* Recupero la Sessione *@
@{
    int idMandatario = Context.Session.GetInt32("IdMandatario") ?? 0;
}

<div class="d-flex align-items-center mb-4">
    <i class="bi bi-table text-primary me-3" style="font-size: 2.5rem;"></i>
    <div>
        <h1 class="h3 mb-0 fw-bold">Lista Ordini COBRAL</h1>
        <small class="text-muted">Visualizza gli ordini importati dal file selezionato</small>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-info">
                Nessun ordine trovato per questo file.
            </div>
        }
        else
        {
            <style>
                #ordiniTable tbody tr:hover {
                    background-color: #e8f1ff !important;
                    cursor: pointer;
                }
            </style>

            <table id="ordiniTable" class="table table-striped table-hover">

                <thead class="table-dark">

                    <!-- Intestazioni -->
                    <tr>
                        <th style="display:none;">ID</th> <!-- colonna ID nascosta -->
                        <th>Ordine</th>
                        <th>DDT</th>
                        <th>Fattura</th>
                        <th>Cliente</th>
                        <th>Materiale</th>
                        <th>Kg</th>
                        <th>Commissioni €</th>
                        <th>Data</th>
                        <th style="width: 60px;">Azioni</th>
                    </tr>

                    <!-- Filtri colonna -->
                    <tr class="filters">
                        <th style="display:none;"></th> @* filtro ID nascosto *@
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filtra Ordine" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filtra DDT" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filtra Fattura" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filtra Cliente" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filtra Materiale" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filtra Kg" /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filtra Comm." /></th>
                        <th><input type="text" class="form-control form-control-sm" placeholder="Filtra Data" /></th>
                        <th></th> @* colonna Azioni, senza filtro *@
                    </tr>


                </thead>

                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr data-id="@p.IdProspettoCobral">
                            @* Aggiunge data-id="@p.IdProspettoCobral" direttamente nel tag <tr>. *@
                            <td style="display:none;">@p.IdProspettoCobral</td> <!-- nascosta -->
                            <td>@p.NumeroOrdine</td>
                            <td>@p.NumeroDDT</td>
                            <td>@p.NumeroFattura</td>
                            <td>@p.RagioneSociale</td>
                            <td>@p.DescrizioneMateriale</td>
                            <td>@p.Quantita</td>
                            <td>@p.ValoreCommissioni</td>
                            <td>@p.DataConsegnaIpotetica?.ToShortDateString()</td>

                            <!-- Colonna Azioni -->
                            <td class="text-center">
                                <a href="/Admin/ProspettiCobral/DettaglioOrdine/@p.IdProspettoCobral"
                                   class="text-primary"
                                   title="Vedi dettaglio">
                                    <i class="bi bi-eye-fill" style="font-size: 1.2rem;"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <a href="/Admin/ProspettiCobral/Importa?idMandatario=@idMandatario"
           class="btn btn-secondary mt-3">
            Importa un nuovo file COBRAL
        </a>

    </div>
</div>

@section Scripts {

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Popper (richiesto da Bootstrap 5 per dropdown) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.11.8/umd/popper.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"></script>

    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <!-- Buttons -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>

    <!-- Excel -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

    <!-- PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <!-- Script DataTables con filtri colonna -->
    <script>
        $(document).ready(function () {

            var table = $('#ordiniTable').DataTable({

                dom: 'Bfrtip',
                buttons: [
                    'excelHtml5',
                    'pdfHtml5',
                    'print'
                ],

                pageLength: 10,
                paging: true,
                lengthChange: true,
                info: true,

                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/it-IT.json"
                },

                columnDefs: [
                    { targets: 0, visible: false, searchable: false } // ID nascosto
                ]
            });

            // Filtri colonna
            $('#ordiniTable thead tr.filters th').each(function (i) {
                $('input', this).on('keyup change', function () {
                    table.column(i).search(this.value).draw();
                });
            });

            // Doppio click → dettaglio ordine
            $('#ordiniTable tbody').on('dblclick', 'tr', function (e) {

                if ($(e.target).is('input, button, a, i')) return;

                var id = $(this).data('id');

                if (id) {
                    window.location.href = '/Admin/ProspettiCobral/DettaglioOrdine/' + id;
                }
            });

        });
    </script>

}
