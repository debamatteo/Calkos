@{
    /*
     * VIEW: Importazione Ordini COBRAL
     *
     * Questa pagina permette di caricare un file Excel COBRAL.
     *
     * Il Mandatario è fisso:
     * COBRAL = IdMandatario = 1
     *
     * La pipeline di importazione è gestita dal controller:
     * - Legge Excel
     * - Converte righe in ImportCobral
     * - Crea FileImportato
     * - Avvia ImportazioneService
     * - Mostra modale di conferma
     */
    ViewData["Title"] = "Importazione Ordini COBRAL";
}

<div class="d-flex align-items-center mb-4">
    <i class="bi bi-upload text-success me-3" style="font-size: 2.5rem;"></i>
    <div>
        <h1 class="h3 mb-0 fw-bold">Importazione Ordini COBRAL</h1>
        <small class="text-muted">Carica un file Excel per generare i prospetti COBRAL</small>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">

        @* Messaggio di errore se il file non è valido *@
        @if (TempData["Errore"] != null)
        {
            <div class="alert alert-danger">@TempData["Errore"]</div>
        }
        @if (TempData["BackupWarning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <strong>Attenzione:</strong> @TempData["BackupWarning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @* FORM DI IMPORTAZIONE *@
        <form method="post" enctype="multipart/form-data">

            @* remmo ora uso la sessione *@
         @*    <input type="hidden" name="idMandatario" value="@ViewBag.IdMandatario" /> *@

            <div class="mb-3">
                <label class="form-label fw-bold">Seleziona file da Importare</label>
                <input type="file" name="fileExcel" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-success">
                <i class="bi bi-play-fill me-1"></i> Avvia Importazione
            </button>

            @* MODALE DI CONFERMA IMPORTAZIONE *@
            @if (TempData["ImportSuccess"] != null)
            {
                <div class="modal fade show" id="importSuccessModal" tabindex="-1" style="display:block; background:rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content shadow">

                            <div class="modal-header bg-success text-white">
                                <h5 class="modal-title">Importazione completata</h5>
                            </div>

                            <div class="modal-body">
                                <p>Il file COBRAL è stato importato correttamente.</p>
                                <p>Vuoi visualizzare subito gli ordini importati?</p>
                            </div>

                            <div class="modal-footer">

                                @* Redirect alla lista ordini COBRAL *@
                                <a class="btn btn-primary"
                                   href="/Admin/ProspettiCobral/ListaOrdini?idFileImportato=@TempData["IdFileImportato"]">
                                    Vai alla Lista Ordini COBRAL
                                </a>

                                <button class="btn btn-secondary" onclick="closeModal()">Rimani qui</button>
                            </div>

                        </div>
                    </div>
                </div>

                <script>
                    function closeModal() {
                        document.getElementById("importSuccessModal").style.display = "none";
                    }
                </script>
            }

        </form>

    </div>
</div>
