@model CalkosManager.Domain.Entities.TipoPagamento

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Nuovo Tipo Pagamento";
}

<div class="container-fluid">
    <h3 class="mt-4 mb-3 fw-bold text-primary">
        <i class="bi bi-credit-card-2-back-fill me-2"></i> @ViewData["Title"]
    </h3>

    <form asp-area="Admin" asp-controller="TipoPagamento" asp-action="Save" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="IdTipoPagamento" value="0" />

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="row g-3">

                    @* Codice Tipo Pagamento *@
                    <div class="col-md-4">
                        <label asp-for="CodiceTipoPagamento" class="form-label fw-bold">Codice</label>
                        <input asp-for="CodiceTipoPagamento" class="form-control" placeholder="Es: BON, RIBA, CONT" />
                        <span asp-validation-for="CodiceTipoPagamento" class="text-danger small"></span>
                    </div>

                    @* Descrizione Tipo Pagamento (CORRETTO) *@
                    <div class="col-md-8">
                        <label asp-for="DescrizioneTipoPagamento" class="form-label fw-bold required-label">Descrizione Pagamento</label>
                        <input asp-for="DescrizioneTipoPagamento" class="form-control" placeholder="Inserisci descrizione (es. Bonifico Bancario 30gg)" />
                        <span asp-validation-for="DescrizioneTipoPagamento" class="text-danger small"></span>
                    </div>

                    @* Opzione Dashboard *@
                    <div class="col-md-6">
                        <label class="form-label fw-bold d-block">Visibilità</label>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" role="switch" asp-for="VisualizzaInDashboard" id="switchDash">
                            <label class="form-check-label" for="switchDash">Visualizza in Dashboard</label>
                        </div>
                    </div>

                    @* Ordine Visualizzazione *@
                    <div class="col-md-6">
                        <label asp-for="OrdineVisualizzazione" class="form-label fw-bold">Ordine di apparizione</label>
                        <input asp-for="OrdineVisualizzazione" type="number" class="form-control" />
                        <span asp-validation-for="OrdineVisualizzazione" class="text-danger small"></span>
                    </div>

                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger mt-3 small"></div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Annulla
                    </a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                        <i class="bi bi-save"></i> Salva Pagamento
                    </button>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $.ajaxSetup({
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                }
            });
        });
    </script>
}