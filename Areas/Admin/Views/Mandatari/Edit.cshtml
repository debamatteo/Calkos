@model CalkosManager.Domain.Entities.Mandatario
@using System.Globalization

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    bool isEdit = Model.IdMandatario > 0;
    ViewData["Title"] = isEdit ? "Modifica Mandatario" : "Nuovo Mandatario";
}

@functions {
    public string FormatDecimal(object? valore, int decimali = 2)
    {
        if (valore == null || valore == DBNull.Value) return string.Empty;
        if (decimal.TryParse(valore.ToString(), out decimal d))
        {
            return d.ToString("F" + decimali, CultureInfo.InvariantCulture);
        }
        return valore.ToString() ?? string.Empty;
    }
}

<div class="container-fluid">
    <h3 class="mt-4 mb-3 fw-bold text-primary">
        <i class="bi @(isEdit ? "bi-building-check" : "bi-building-add") me-2"></i> @ViewData["Title"]
    </h3>

    @* RIPRISTINATA ACTION ORIGINALE: Edit *@
    <form asp-area="Admin" asp-controller="Mandatari" asp-action="Edit" method="post" id="formMandatario">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdMandatario" id="hfMandatarioId" />

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2 text-primary"></i>Dati Generali</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="NomeMandatario" class="form-label fw-bold required-label"></label>
                        <input asp-for="NomeMandatario" class="form-control" placeholder="Inserisci nome mandatario" />
                        <span asp-validation-for="NomeMandatario" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CodiceMandatario" class="form-label fw-bold required-label"></label>
                        <input asp-for="CodiceMandatario" class="form-control" placeholder="Inserisci codice identificativo" />
                        <span asp-validation-for="CodiceMandatario" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        @if (isEdit)
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-people me-2 text-primary"></i>Associazione Clienti</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end mb-4">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Cerca Cliente</label>
                            <div class="position-relative">
                                <input id="clienteSearch" type="text" class="form-control" placeholder="Digita almeno 2 caratteri (Ragione Sociale, P.Iva...)" autocomplete="off" />
                                <ul id="autocompleteResults" class="list-group position-absolute w-100 shadow-sm" style="z-index: 1000; max-height: 200px; overflow-y: auto;"></ul>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <button id="btnAddCliente" type="button" class="btn btn-dark w-100 fw-bold">
                                <i class="bi bi-plus-lg"></i> Aggiungi Cliente
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table id="clientiAssociatiTable" class="table table-hover align-middle border">
                            <thead class="table-light">
                                <tr>
                                    <th>Cliente</th>
                                    <th style="width: 100px;" class="text-center">Azioni</th>
                                </tr>
                                <tr class="filters bg-white">
                                    <th class="py-1">
                                        <input type="text" class="form-control form-control-sm" placeholder="Filtra nella lista..." />
                                    </th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="clientiAssociatiBody">
                                @* Caricato via AJAX *@
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger mt-3 small"></div>

        <div class="mt-4 pt-3 border-top d-flex justify-content-between mb-5">
            <a asp-area="Admin" asp-controller="Mandatari" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Annulla
            </a>
            <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                <i class="bi bi-save"></i> Salva Mandatario
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const currentMandatarioId = $("#hfMandatarioId").val();

            // Setup CSRF per AJAX
            $.ajaxSetup({
                headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() }
            });

            // Prevenzione submit su INVIO negli input
            $(document).on("keydown", "input", function (e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    return false;
                }
            });

            // --- LOGICA AUTOCOMPLETE ---
            $("#clienteSearch").on("keyup", function () {
                let term = $(this).val();
                if (term.length < 2) {
                    $("#autocompleteResults").empty();
                    return;
                }
                $.getJSON("/Admin/Clienti/Search", { term: term }, function (data) {
                    $("#autocompleteResults").empty();
                    data.forEach(function (item) {
                        $("#autocompleteResults").append(
                            `<li class='list-group-item list-group-item-action cliente-item'
                                 data-id='${item.id}' data-text='${item.text.replace(/'/g, "&#39;")}'>
                                 ${item.text}
                             </li>`
                        );
                    });
                });
            });

            $(document).on("click", ".cliente-item", function () {
                $("#clienteSearch").val($(this).data("text")).data("selected-id", $(this).data("id"));
                $("#autocompleteResults").empty();
            });

            // --- AGGIUNTA CLIENTE ---
            $("#btnAddCliente").on("click", function () {
                let idCliente = $("#clienteSearch").data("selected-id");
                if (!idCliente) {
                    alert("Seleziona un cliente dall'elenco.");
                    return;
                }
                $.post("/Admin/Mandatari/AddCliente", { idMandatario: currentMandatarioId, idCliente: idCliente }, function () {
                    loadClientiAssociati();
                    $("#clienteSearch").val("").data("selected-id", null);
                });
            });

            // --- CARICAMENTO TABELLA ---
            function loadClientiAssociati() {
                if (currentMandatarioId == "0") return;
                $.getJSON("/Admin/Mandatari/GetClienti", { idMandatario: currentMandatarioId }, function (data) {
                    let $body = $("#clientiAssociatiBody").empty();
                    if (data.length === 0) {
                        $body.append("<tr><td colspan='2' class='text-center text-muted'>Nessun cliente associato</td></tr>");
                        return;
                    }
                    data.forEach(function (c) {
                        $body.append(`
                            <tr>
                                <td class="fw-bold">${c.ragioneSociale}</td>
                                <td class='text-center'>
                                    <button type='button' class='btn btn-outline-danger btn-sm shadow-sm' onclick='removeCliente(${c.idCliente})'>
                                        <i class='bi bi-trash'></i>
                                    </button>
                                </td>
                            </tr>`);
                    });
                    applicaFiltro();
                });
            }

            // Inizializzazione se in Edit
            if (currentMandatarioId != "0") loadClientiAssociati();
        });

        // --- RIMOZIONE (Global per onclick) ---
        function removeCliente(idCliente) {
            if (confirm("Scollegare questo cliente dal mandatario?")) {
                $.post("/Admin/Mandatari/RemoveCliente", {
                    idMandatario: $("#hfMandatarioId").val(),
                    idCliente: idCliente
                }, function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                });
            }
        }

        // --- FILTRO TABELLA ---
        function applicaFiltro() {
            let value = $(".filters input").val().toLowerCase();
            $("#clientiAssociatiBody tr").each(function () {
                let text = $(this).find("td:first").text().toLowerCase();
                if (!text.includes("nessun cliente")) $(this).toggle(text.indexOf(value) > -1);
            });
        }

        $(document).on("keyup", ".filters input", applicaFiltro);
    </script>
}