@* @model IEnumerable<ErroreImportCobral>

@{
    ViewData["Title"] = "Errori di importazione COBRAL";
}
 *@
<div class="d-flex align-items-center mb-4">
    <i class="bi bi-exclamation-triangle text-danger me-3" style="font-size: 2.5rem;"></i>
    <div>
        <h1 class="h3 mb-0 fw-bold">Errori di importazione COBRAL</h1>
        <small class="text-muted">File #@ViewBag.IdFileImportato</small>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-success mb-0">
                Nessun errore registrato per questo file.
            </div>
        }
        else
        {
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Riga</th>
                        <th>Messaggio</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td>@e.Riga</td>
                            <td>@e.Messaggio</td>
                            <td>@e.DataErrore.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
