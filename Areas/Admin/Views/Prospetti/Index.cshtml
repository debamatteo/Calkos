@using CalkosManager.Domain.Entities
@model IEnumerable<Mandatario>

@{
    ViewData["Title"] = "Gestione Prospetti";
}

<div class="row g-4">

    <!-- CARD: Importa Ordini -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-start position-relative">
                @* FIX: position-relative per evitare che la dropdown venga tagliata *@

                <i class="bi bi-upload text-success me-3" style="font-size: 2.5rem;"></i>

                <div>
                    <h5 class="card-title fw-bold">Importa Ordini</h5>
                    <p class="text-muted mb-3">Carica file Excel</p>

                    <div class="dropdown position-static">
                        @* FIX: position-static per permettere al menu di uscire dal contenitore *@

                        <button class="btn btn-success btn-sm dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            Scegli Mandatario
                        </button>

                        <ul class="dropdown-menu">
                            @foreach (var m in Model)
                            {
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin"
                                       asp-controller="@($"Prospetti{m.CodiceMandatario}")"
                                       asp-action="Importa"
                                       asp-route-idMandatario="@m.IdMandatario">
                                        @m.NomeMandatario
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </div>


    <!-- CARD: Lista Ordini -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-start position-relative">
                @* FIX: position-relative per dropdown *@

                <i class="bi bi-list-ul text-primary me-3" style="font-size: 2.5rem;"></i>

                <div>
                    <h5 class="card-title fw-bold">Lista Ordini</h5>
                    <p class="text-muted mb-3">Visualizza gli ordini importati</p>

                    <div class="dropdown position-static">
                        @* FIX: position-static *@

                        <button class="btn btn-primary btn-sm dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            Scegli Mandatario
                        </button>

                        <ul class="dropdown-menu">
                            @foreach (var m in Model)
                            {
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin"
                                       asp-controller="@($"Prospetti{m.CodiceMandatario}")"
                                       asp-action="ListaOrdini">
                                        @m.NomeMandatario
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </div>


    <!-- CARD: Riepilogo Fatture -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-start position-relative">
                @* FIX: position-relative *@

                <i class="bi bi-receipt text-warning me-3" style="font-size: 2.5rem;"></i>

                <div>
                    <h5 class="card-title fw-bold">Riepilogo Fatture</h5>
                    <p class="text-muted mb-3">Totali e aggregazioni</p>

                    <div class="dropdown position-static">
                        @* FIX: position-static *@

                        <button class="btn btn-warning btn-sm dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            Scegli Mandatario
                        </button>

                        <ul class="dropdown-menu">
                            @foreach (var m in Model)
                            {
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin"
                                       asp-controller="@($"Prospetti{m.CodiceMandatario}")"
                                       asp-action="RiepilogoFatture">
                                        @m.NomeMandatario
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </div>


    <!-- CARD: Riepilogo Totali -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-start position-relative">
                @* FIX: position-relative *@

                <i class="bi bi-bar-chart text-info me-3" style="font-size: 2.5rem;"></i>

                <div>
                    <h5 class="card-title fw-bold">Riepilogo Totali</h5>
                    <p class="text-muted mb-3">Statistiche e KPI</p>

                    <div class="dropdown position-static">
                        @* FIX: position-static *@

                        <button class="btn btn-info btn-sm dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            Scegli Mandatario
                        </button>

                        <ul class="dropdown-menu">
                            @foreach (var m in Model)
                            {
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin"
                                       asp-controller="@($"Prospetti{m.CodiceMandatario}")"
                                       asp-action="RiepilogoTotali">
                                        @m.NomeMandatario
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </div>

</div>
@section Scripts {
    <!-- Bootstrap JS (se non già nel layout) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
}
