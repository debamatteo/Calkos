@model Calkos.Web.Models.Admin.UserDetailsViewModel


@{
    ViewData["Title"] = "Dettagli Utente";
}

<!-- Header moderno -->
<div class="d-flex align-items-center mb-4">
    <i class="bi bi-person-badge-fill text-info me-3" style="font-size: 2.5rem;"></i>
    <div>
        <h1 class="h3 mb-0 fw-bold">Dettagli Utente</h1>
        <small class="text-muted">Informazioni complete sull’utente selezionato</small>
    </div>
</div>

<!-- Card con i dati utente -->
<div class="card shadow-sm mb-4">
    <div class="card-body">

        <!-- Email -->
        <div class="mb-3">
            <span class="text-muted">Email:</span>
            <strong>@Model.Email</strong>
        </div>

        <!-- Id utente -->
        <div class="mb-3">
            <span class="text-muted">User ID:</span>
            <code>@Model.UserId</code>
        </div>

        <!-- Ruoli -->
        <div class="mb-3">
            <span class="text-muted">Ruoli assegnati:</span>
            <div class="mt-1">
                @if (Model.Roles.Any())
                {
                    foreach (var role in Model.Roles)
                    {
                        <span class="badge bg-primary me-1">@role</span>
                    }
                }
                else
                {
                    <span class="badge bg-secondary">Nessun ruolo</span>
                }
            </div>
        </div>

    </div>
</div>

<!-- Pulsanti -->
<div class="d-flex justify-content-between">
    <a asp-area="Admin"
       asp-controller="Users"
       asp-action="Index"
       class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Torna alla lista
    </a>

    <a asp-area="Admin"
       asp-controller="Users"
       asp-action="ManageRoles"
       asp-route-id="@Model.UserId"
       class="btn btn-primary">
        <i class="bi bi-shield-lock"></i> Gestisci Ruoli
    </a>
</div>
