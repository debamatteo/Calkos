@model Calkos.Web.Models.ApplicationUser

<h2>Modifica Utente</h2>

<form method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Salva</button>
</form>
