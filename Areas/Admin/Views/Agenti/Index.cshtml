@model IEnumerable<CalkosManager.Domain.Entities.Agente>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Gestione Anagrafica Agenti";
}

@* HEADER: sezione introduttiva della pagina con titolo e descrizione *@
<div class="d-flex align-items-center mb-4">
    <i class="bi bi-people-fill text-primary me-3" style="font-size: 2.5rem;"></i>
    <div>
        <h1 class="h3 mb-0 fw-bold">Anagrafica Agenti</h1>
        <small class="text-muted">Gestione e ricerca agenti tramite mappatura diretta delle colonne</small>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">

        @* TOOLBAR: pulsanti principali (nuovo agente + reset filtri) *@
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex gap-2">
                <a asp-area="Admin" asp-controller="Agenti" asp-action="Create"
                   class="btn btn-primary fw-bold shadow-sm">
                    <i class="bi bi-person-plus-fill me-1"></i> Nuovo Agente
                </a>
                <button type="button" class="btn btn-outline-secondary btn-sm"
                        onclick="resetFiltri()">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset Filtri
                </button>
            </div>
        </div>

        <style>
            /* STILE UNIFORMATO: Header Blu e righe pulite */
            #agentiTable thead tr:first-child th {
                background-color: #0d6efd !important;
                color: white !important;
                border: none !important;
                padding: 12px 10px !important;
            }

            #agentiTable thead tr.filters th {
                background-color: #f8f9fa !important;
                border-bottom: 1px solid #dee2e6 !important;
                padding: 8px !important;
            }

            #agentiTable tbody tr:hover {
                background-color: #f0f7ff !important;
                cursor: pointer;
            }

            .filters input {
                width: 100%;
                font-size: 0.75rem;
                padding: 3px 6px;
                border: 1px solid #dee2e6;
                border-radius: 4px;
            }

            .ps-custom {
                padding-left: 1.2rem !important;
            }

            .badge-percent {
                background-color: #e7f1ff;
                color: #0d6efd;
                border: 1px solid #cfe2ff;
                font-weight: 600;
            }
        </style>

        <div class="table-responsive">
            <table id="agentiTable" class="table table-hover align-middle w-100">
                <thead>
                    @* RIGA 1: intestazioni colonna (usate da DataTables per ordinamento) *@
                    <tr>
                        <th style="display:none;">ID</th>                 @* Index 0 *@
                        <th class="ps-custom">Agente</th>                @* Index 1 *@
                        <th>Partita IVA / CF</th>                        @* Index 2 *@
                        <th class="text-end" style="width: 120px;">% Default</th> @* Index 3 *@
                        <th>Telefono 1</th>                              @* Index 4 *@
                        <th>Telefono 2</th>                              @* Index 5 *@
                        <th>Email</th>                                   @* Index 6 *@
                        <th class="text-center" style="width:110px;">Azioni</th> @* Index 7 *@
                    </tr>

                    @* RIGA 2: filtri — mappatura manuale data-col *@
                    <tr class="filters">
                        <th style="display:none;"></th>
                        <th class="ps-custom"><input type="text" placeholder="Inizia con..." data-col="1" /></th>
                        <th><input type="text" placeholder="Cerca..." data-col="2" /></th>
                        <th>
                            <div class="input-group input-group-sm">
                                <input type="number" step="0.01" class="form-control" placeholder="%" data-col="3" />
                            </div>
                        </th>
                        <th><input type="text" placeholder="Cerca..." data-col="4" /></th>
                        <th><input type="text" placeholder="Cerca..." data-col="5" /></th>
                        <th><input type="text" placeholder="Cerca..." data-col="6" /></th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr data-id="@a.IdAgente">
                            <td style="display:none;">@a.IdAgente</td>
                            <td class="fw-bold text-dark ps-custom">@a.AgenteDescrizione</td>
                            <td>
                                <span class="badge bg-light text-dark border fw-normal">
                                    @(string.IsNullOrWhiteSpace(a.PartitaIva) ? a.CodiceFiscale : a.PartitaIva)
                                </span>
                            </td>
                            <td class="text-end">
                                @if (a.PercentualeDefault.HasValue)
                                {
                                    <span class="badge badge-percent">
                                        @a.PercentualeDefault.Value.ToString("F2") %
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@a.Telefono1</td>
                            <td>@a.Telefono2</td>
                            <td><small class="text-muted">@a.Email</small></td>

                            <td class="text-center text-nowrap">
                                <a asp-action="Edit" asp-route-id="@a.IdAgente"
                                   class="btn btn-link text-warning p-0 me-2"
                                   title="Modifica agente">
                                    <i class="bi bi-pencil-square fs-5"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-link text-danger p-0"
                                        onclick="eliminaAgente(@a.IdAgente, this)"
                                        title="Elimina agente">
                                    <i class="bi bi-trash-fill fs-5"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

@* Token antifrode per richieste AJAX - Necessario per le operazioni di eliminazione *@
<div id="antiforgery-container" style="display:none;">
    @Html.AntiForgeryToken()
</div>

@* ... (resto della View invariato fino ai tag Script) ... *@

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

            /**
             * CENTRALIZZAZIONE ANTIFORGERY
             * Configuriamo jQuery per leggere il token dal form hidden una volta sola.
             * Questo header verrà inviato automaticamente in ogni $.post o $.ajax.
             */
            $.ajaxSetup({
                headers: {
                    "RequestVerificationToken": $('#antiForgeryForm input[name="__RequestVerificationToken"]').val()
                }
            });

            // INIZIALIZZAZIONE DATATABLES
            var table = $('#agentiTable').DataTable({
                dom: '<"d-flex justify-content-between mb-2"l>rtip',
                orderCellsTop: true,
                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/it-IT.json"
                },
                columnDefs: [
                    { targets: 0, visible: false, searchable: false },
                    { targets: 7, orderable: false, searchable: false }
                ],
                order: [[1, 'asc']]
            });

            // FILTRO PERCENTUALE (col 3)
            $('#agentiTable thead tr.filters input[data-col="3"]').on('keyup change', function () {
                var val = this.value;
                if (!val) {
                    table.column(3).search("").draw();
                    return;
                }
                var regex = "^" + parseFloat(val).toFixed(2);
                table.column(3).search(regex, true, false).draw();
            });

            // FILTRI STANDARD
            $('#agentiTable thead tr.filters input:not([data-col="3"])').on('keyup change', function () {
                var colIndex = $(this).data('col');
                var searchVal = this.value;
                table.column(colIndex).search(
                    searchVal ? "^" + searchVal : "",
                    true,
                    false
                ).draw();
            });

            $('.filters th').on('click', function (e) {
                e.stopPropagation();
            });

            // DOPPIO CLICK → EDIT
            $('#agentiTable tbody').on('dblclick', 'tr', function (e) {
                if ($(e.target).closest('a, button').length > 0) return;
                var id = $(this).data('id');
                if (id) window.location.href = '@Url.Action("Edit", "Agenti")/' + id;
            });
        });

        // RESET FILTRI
        function resetFiltri() {
            $('.filters input').val('');
            $('#agentiTable').DataTable().search('').columns().search('').draw();
        }

        // ELIMINAZIONE AGENTE (AJAX con Antiforgery centralizzato)
        function eliminaAgente(id, btn) {
            $('#confirmDeleteModal .modal-body').html("Sei sicuro di voler eliminare questo agente?<br><span class='text-danger fw-bold'>L'operazione è definitiva.</span>");

            var modalConferma = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
            modalConferma.show();

            $('#confirmDeleteBtn').off('click').on('click', function () {
                modalConferma.hide();

                /**
                 * NOTA: Non passiamo più il token manualmente nel corpo dati.
                 * Ci pensa $.ajaxSetup configurato sopra nell'header.
                 */
                $.post('@Url.Action("Delete", "Agenti")', { id: id })
                    .done(function (res) {
                        if (res.success) {
                            $('#agentiTable').DataTable()
                                .row($(btn).closest('tr'))
                                .remove()
                                .draw(false);

                            $('#modalOperazioneCompletata .modal-body').text("Agente eliminato con successo.");
                            var modalSuccesso = new bootstrap.Modal(document.getElementById('modalOperazioneCompletata'));
                            modalSuccesso.show();
                        } else {
                            alert(res.message || "Errore durante l'eliminazione.");
                        }
                    })
                    .fail(function() {
                        alert("Errore tecnico durante la richiesta al server.");
                    });
            });
        }
    </script>
}