@model CalkosManager.Domain.Entities.Agente
@using System.Globalization

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = Model.IdAgente == 0 ? "Nuovo Agente" : "Modifica Agente";
}

@functions {
    // Helper per gestire la formattazione dei decimali in modo neutro rispetto alla localizzazione del server
    public string FormatDecimal(object? valore, int decimali = 2)
    {
        if (valore == null || valore == DBNull.Value) return string.Empty;
        if (decimal.TryParse(valore.ToString(), out decimal d))
        {
            return d.ToString("F" + decimali, CultureInfo.InvariantCulture);
        }
        return valore.ToString() ?? string.Empty;
    }
}

<div class="container-fluid">
    <h3 class="mt-4 mb-3 fw-bold text-secondary">
        <i class="bi bi-person-plus-fill me-2"></i> @ViewData["Title"]
    </h3>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @* 
               Il Tag Helper asp-action genera automaticamente il token Antiforgery hidden.
               Rimuoviamo @Html.AntiForgeryToken() se presente nel form per evitare duplicati.
            *@
            <form asp-action="Save" method="post">
                <input type="hidden" asp-for="IdAgente" />

                <div class="row g-3">
                    @* Nome e Cognome *@
                    <div class="col-md-6">
                        <label asp-for="Nome" class="form-label fw-bold required-label">Nome</label>
                        <input asp-for="Nome" class="form-control" placeholder="Inserisci il nome" />
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Cognome" class="form-label fw-bold required-label">Cognome</label>
                        <input asp-for="Cognome" class="form-control" placeholder="Inserisci il cognome" />
                        <span asp-validation-for="Cognome" class="text-danger small"></span>
                    </div>

                    @* P.IVA e CF *@
                    <div class="col-md-6">
                        <label asp-for="PartitaIva" class="form-label fw-bold">Partita IVA</label>
                        <input asp-for="PartitaIva" class="form-control" maxlength="11" />
                        <span asp-validation-for="PartitaIva" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CodiceFiscale" class="form-label fw-bold">Codice Fiscale</label>
                        <input asp-for="CodiceFiscale" class="form-control" maxlength="16" />
                        <span asp-validation-for="CodiceFiscale" class="text-danger small"></span>
                    </div>

                    @* Percentuale e Email *@
                    <div class="col-md-6">
                        <label asp-for="PercentualeDefault" class="form-label fw-bold">Provvigione Default (%)</label>
                        <div class="input-group">
                            <input asp-for="PercentualeDefault" type="number" step="0.01" class="form-control"
                                   value="@FormatDecimal(Model.PercentualeDefault, 2)" />
                            <span class="input-group-text">%</span>
                        </div>
                        <span asp-validation-for="PercentualeDefault" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="esempio@mail.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    @* Contatti Telefonici *@
                    <div class="col-md-6">
                        <label asp-for="Telefono1" class="form-label fw-bold">Telefono Principale</label>
                        <input asp-for="Telefono1" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Telefono2" class="form-label fw-bold">Telefono Secondario</label>
                        <input asp-for="Telefono2" class="form-control" />
                    </div>
                </div>

                @* Sommario errori *@
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-3 small"></div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Annulla
                    </a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                        <i class="bi bi-save"></i> Salva Agente
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            /**
             * CENTRALIZZAZIONE ANTIFORGERY
             * Anche se questa pagina usa un form standard, configuriamo jQuery AJAX
             * recuperando il token generato automaticamente dal Tag Helper del form.
             */
            $.ajaxSetup({
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                }
            });
        });
    </script>
}