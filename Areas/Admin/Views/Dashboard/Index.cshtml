@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4">

    <!-- Gestione Utenti -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-start">
                <i class="bi bi-people-fill text-primary me-3" style="font-size: 2.5rem;"></i>
                <div>
                    <h5 class="card-title fw-bold">Gestione Utenti</h5>
                    <p class="text-muted mb-3">Visualizza e gestisci gli utenti registrati</p>
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-primary btn-sm">
                        Vai alla sezione
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Gestione Ruoli -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-start">
                <i class="bi bi-shield-lock-fill text-success me-3" style="font-size: 2.5rem;"></i>
                <div>
                    <h5 class="card-title fw-bold">Gestione Ruoli</h5>
                    <p class="text-muted mb-3">Crea, modifica e assegna ruoli agli utenti</p>
                    <a asp-area="Admin" asp-controller="Roles" asp-action="Index" class="btn btn-success btn-sm">
                        Vai alla sezione
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Pagina in Costruzione -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body d-flex align-items-start">
                <i class="bi bi-graph-up-arrow text-warning me-3" style="font-size: 2.5rem;"></i>
                <div>
                    <h5 class="card-title fw-bold">Gestione Prospetti</h5>
                    <p class="text-muted mb-3">Sezione dedicata alla gestione dei Prospetti</p>
                    <a asp-area="Admin" asp-controller="Prospetti" asp-action="Index" class="btn btn-warning btn-sm text-white">
                        Vai alla sezione
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>
