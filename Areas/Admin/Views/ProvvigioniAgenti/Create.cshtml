@model CalkosManager.Domain.Entities.ProvvigioniAgenti

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Nuova Provvigione";
}

<div class="container-fluid">
    <h3 class="mt-4 mb-3 fw-bold text-primary">
        <i class="bi bi-plus-circle-fill me-2"></i> @ViewData["Title"]
    </h3>

    <form asp-area="Admin" asp-controller="ProvvigioniAgenti" asp-action="Save" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="IdProvvigione" value="0" />

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="row g-3">

                    <!-- AGENTE -->
                    <div class="col-md-6">
                        <label asp-for="IdAgente" class="form-label fw-bold">Agente</label>
                        <select asp-for="IdAgente" class="form-select select2" asp-items="ViewBag.Agenti">
                            <option value="">-- Seleziona Agente --</option>
                        </select>
                        <span asp-validation-for="IdAgente" class="text-danger small"></span>
                    </div>

                    <!-- MANDATARIO -->
                    <div class="col-md-6">
                        <label asp-for="IdMandatario" class="form-label fw-bold">Mandatario</label>
                        <select asp-for="IdMandatario" class="form-select select2" asp-items="ViewBag.Mandatari">
                            <option value="">-- Seleziona Mandatario --</option>
                        </select>
                        <span asp-validation-for="IdMandatario" class="text-danger small"></span>
                    </div>

                    <!-- CLIENTE (OPZIONALE) -->
                    <div class="col-md-6">
                        <label asp-for="IdCliente" class="form-label fw-bold">Cliente (opzionale)</label>
                        <select asp-for="IdCliente" class="form-select select2" asp-items="ViewBag.Clienti">
                            <option value="">-- Nessun Cliente Specifico (Tutti) --</option>
                        </select>
                        <span asp-validation-for="IdCliente" class="text-danger small"></span>
                    </div>

                    <!-- PERCENTUALE -->
                    <div class="col-md-6">
                        <label asp-for="Percentuale" class="form-label fw-bold">Percentuale Provvigione (%)</label>
                        <div class="input-group">
                            <input asp-for="Percentuale"
                                   type="number"
                                   step="0.01"
                                   min="0"
                                   max="100"
                                   class="form-control"
                                   placeholder="0.00" />
                            <span class="input-group-text bg-light">%</span>
                        </div>
                        <span asp-validation-for="Percentuale" class="text-danger small"></span>
                    </div>

                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger mt-3 small"></div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Annulla
                    </a>

                    <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                        <i class="bi bi-save"></i> Salva Provvigione
                    </button>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            /**
             * CENTRALIZZAZIONE ANTIFORGERY (Coerenza Progetto)
             */
            $.ajaxSetup({
                headers: {
                    "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                }
            });

            // Inizializzazione componenti UI
            if ($.fn.select2) {
                $('.select2').select2({
                    theme: 'bootstrap-5',
                    width: '100%'
                });
            }
        });
    </script>
}