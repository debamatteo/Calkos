@model CalkosManager.Domain.Entities.ProvvigioniAgenti

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Modifica Provvigione";
}

<div class="container-fluid">
    <h3 class="mt-4 mb-3 fw-bold text-secondary">
        <i class="bi bi-pencil-square me-2"></i> @ViewData["Title"]
    </h3>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-area="Admin" asp-controller="ProvvigioniAgenti" asp-action="Save" method="post">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="IdProvvigione" />

                <div class="row g-3">

                    <!-- AGENTE -->
                    <div class="col-md-6">
                        <label asp-for="IdAgente" class="form-label fw-bold">Agente</label>
                        <select asp-for="IdAgente" class="form-select" asp-items="ViewBag.Agenti">
                            <option value="">-- Seleziona Agente --</option>
                        </select>
                        <span asp-validation-for="IdAgente" class="text-danger small"></span>
                    </div>

                    <!-- MANDATARIO -->
                    <div class="col-md-6">
                        <label asp-for="IdMandatario" class="form-label fw-bold">Mandatario</label>
                        <select asp-for="IdMandatario" class="form-select" asp-items="ViewBag.Mandatari">
                            <option value="">-- Seleziona Mandatario --</option>
                        </select>
                        <span asp-validation-for="IdMandatario" class="text-danger small"></span>
                    </div>

                    <!-- CLIENTE (OPZIONALE) -->
                    <div class="col-md-6">
                        <label asp-for="IdCliente" class="form-label fw-bold">Cliente (opzionale)</label>
                        <select asp-for="IdCliente" class="form-select" asp-items="ViewBag.Clienti">
                            <option value="">-- Nessun Cliente Specifico (Tutti) --</option>
                        </select>
                        <span asp-validation-for="IdCliente" class="text-danger small"></span>
                    </div>

                    <!-- PERCENTUALE -->
                    <div class="col-md-6">
                        <label asp-for="Percentuale" class="form-label fw-bold">Percentuale (%)</label>
                        <div class="input-group">
                            <input asp-for="Percentuale"
                                   type="number"
                                   step="0.01"
                                   min="0"
                                   max="100"
                                   class="form-control"
                                   placeholder="0.00" />
                            <span class="input-group-text">%</span>
                        </div>
                        <span asp-validation-for="Percentuale" class="text-danger small"></span>
                    </div>

                </div>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-3 small"></div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Annulla
                    </a>

                    <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                        <i class="bi bi-save"></i> Salva Modifiche
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}