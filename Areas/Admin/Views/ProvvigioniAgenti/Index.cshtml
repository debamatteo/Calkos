@model IEnumerable<CalkosManager.Domain.Entities.ProvvigioniAgenti>

@inject CalkosManager.Application.Services.AgenteService AgenteService
@inject CalkosManager.Application.Services.MandatarioService MandatarioService
@inject CalkosManager.Application.Services.ClienteService ClienteService

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Gestione Provvigioni Agenti";

    // Lookup per descrizioni con gestione null per evitare eccezioni durante il rendering
    var agenti = AgenteService.GetAll()?.ToList() ?? new List<CalkosManager.Domain.Entities.Agente>();
    var mandatari = MandatarioService.GetAll()?.ToList() ?? new List<CalkosManager.Domain.Entities.Mandatario>();
    var clienti = ClienteService.GetAll()?.ToList() ?? new List<CalkosManager.Domain.Entities.Cliente>();
}

@* HEADER: sezione introduttiva della pagina con titolo e descrizione (Pattern Modello) *@
<div class="d-flex align-items-center mb-4">
    <i class="bi bi-cash-coin text-primary me-3" style="font-size: 2.5rem;"></i>
    <div>
        <h1 class="h3 mb-0 fw-bold">Provvigioni Agenti</h1>
        <small class="text-muted">Configurazione delle percentuali per Agente, Mandatario e Cliente</small>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">

        @* TOOLBAR: pulsanti principali (Pattern Modello) *@
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex gap-2">
                <a asp-area="Admin" asp-controller="ProvvigioniAgenti" asp-action="Create"
                   class="btn btn-primary fw-bold shadow-sm">
                    <i class="bi bi-plus-circle-fill me-1"></i> Nuova Provvigione
                </a>
                <button type="button" class="btn btn-outline-secondary btn-sm"
                        onclick="resetFiltri()">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset Filtri
                </button>
            </div>
        </div>

        <style>
            /* STILE UNIFORMATO: Header Blu e righe pulite (Adattato da Modello) */
            #provvigioniTable thead tr:first-child th {
                background-color: #0d6efd !important;
                color: white !important;
                border: none !important;
                padding: 12px 10px !important;
            }

            #provvigioniTable thead tr.filters th {
                background-color: #f8f9fa !important;
                border-bottom: 1px solid #dee2e6 !important;
                padding: 8px !important;
            }

            #provvigioniTable tbody tr:hover {
                background-color: #f0f7ff !important;
                cursor: pointer;
            }

            .filters input {
                width: 100%;
                font-size: 0.75rem;
                padding: 3px 6px;
                border: 1px solid #dee2e6;
                border-radius: 4px;
            }

            .ps-custom {
                padding-left: 1.2rem !important;
            }

            .badge-percent {
                background-color: #e7f1ff;
                color: #0d6efd;
                border: 1px solid #cfe2ff;
                font-weight: 600;
            }
        </style>

        <div class="table-responsive">
            <table id="provvigioniTable" class="table table-hover align-middle w-100">
                <thead>
                    @* RIGA 1: intestazioni colonna *@
                    <tr>
                        <th style="display:none;">ID</th>                 @* Index 0 *@
                        <th class="ps-custom">Agente</th>                @* Index 1 *@
                        <th>Mandatario</th>                              @* Index 2 *@
                        <th>Cliente</th>                                 @* Index 3 *@
                        <th class="text-end" style="width: 130px;">% Provv.</th> @* Index 4 *@
                        <th>Utente</th>                                  @* Index 5 *@
                        <th class="text-center" style="width:110px;">Azioni</th> @* Index 6 *@
                    </tr>

                    @* RIGA 2: filtri — mappatura manuale data-col *@
                    <tr class="filters">
                        <th style="display:none;"></th>
                        <th class="ps-custom"><input type="text" placeholder="Filtra Agente..." data-col="1" /></th>
                        <th><input type="text" placeholder="Filtra Mandatario..." data-col="2" /></th>
                        <th><input type="text" placeholder="Filtra Cliente..." data-col="3" /></th>
                        <th>
                            <div class="input-group input-group-sm">
                                <input type="number" step="0.01" class="form-control" placeholder="%" data-col="4" />
                            </div>
                        </th>
                        <th><input type="text" placeholder="Cerca..." data-col="5" /></th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Model)
                    {
                        var agente = agenti.FirstOrDefault(a => a.IdAgente == p.IdAgente);
                        var mandatario = mandatari.FirstOrDefault(m => m.IdMandatario == p.IdMandatario);
                        var cliente = p.IdCliente.HasValue ? clienti.FirstOrDefault(c => c.IdCliente == p.IdCliente) : null;

                        <tr data-id="@p.IdProvvigione">
                            <td style="display:none;">@p.IdProvvigione</td>
                            <td class="fw-bold text-dark ps-custom">@(agente?.AgenteDescrizione ?? "N/D")</td>
                            <td>@(mandatario?.NomeMandatario ?? "N/D")</td>
                            <td>
                                <span class="badge bg-light text-dark border fw-normal">
                                    @(cliente?.RagioneSociale ?? "TUTTI")
                                </span>
                            </td>
                            <td class="text-end">
                                <span class="badge badge-percent">
                                    @p.Percentuale.ToString("F2") %
                                </span>
                            </td>
                            <td><small class="text-muted">@p.Utente</small></td>
                            <td class="text-center text-nowrap">
                                <a asp-action="Edit" asp-route-id="@p.IdProvvigione"
                                   class="btn btn-link text-warning p-0 me-2"
                                   title="Modifica">
                                    <i class="bi bi-pencil-square fs-5"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-link text-danger p-0"
                                        onclick="eliminaProvvigione(@p.IdProvvigione, this)"
                                        title="Elimina">
                                    <i class="bi bi-trash-fill fs-5"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        // Variabili globali per gestire l'eliminazione tramite modale del layout
        let idDaEliminare = 0;
        let rigaDaRimuovere = null;

        $(document).ready(function () {

            // Inizializzazione DataTables
            var table = $('#provvigioniTable').DataTable({
                dom: '<"d-flex justify-content-between mb-2"l>rtip',
                orderCellsTop: true,
                language: {
                    url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/it-IT.json"
                },
                columnDefs: [
                    { targets: 0, visible: false, searchable: false },
                    { targets: 6, orderable: false, searchable: false }
                ],
                order: [[1, 'asc']]
            });

            // Logica Filtri (Testuali e Percentuale)
            $('#provvigioniTable thead tr.filters input').on('keyup change', function () {
                var colIndex = $(this).data('col');
                var val = this.value;

                if (colIndex === 4) { // Colonna Percentuale
                    if (!val) {
                        table.column(4).search("").draw();
                    } else {
                        var regex = "^" + parseFloat(val).toFixed(2);
                        table.column(4).search(regex, true, false).draw();
                    }
                } else { // Altre colonne
                    table.column(colIndex).search(
                        val ? "^" + val : "",
                        true,
                        false
                    ).draw();
                }
            });

            $('.filters th').on('click', function (e) {
                e.stopPropagation();
            });

            // Navigazione rapida su doppio click
            $('#provvigioniTable tbody').on('dblclick', 'tr', function (e) {
                if ($(e.target).closest('a, button').length > 0) return;
                var id = $(this).data('id');
                if (id) window.location.href = '@Url.Action("Edit", "ProvvigioniAgenti")/' + id;
            });

            /**
             * EVENTO CLICK SU BOTTONE MODALE LAYOUT
             */
            $('#confirmDeleteBtn').on('click', function () {
                eseguiEliminazione();
            });
        });

        /**
         * RESET FILTRI
         */
        function resetFiltri() {
            $('.filters input').val('');
            $('#provvigioniTable').DataTable().search('').columns().search('').draw();
        }

        /**
         * APERTURA MODALE DI CONFERMA
         */
        function eliminaProvvigione(id, btn) {
            idDaEliminare = id;
            rigaDaRimuovere = $(btn).closest('tr');

            let info = rigaDaRimuovere.find('td:eq(0)').text().trim();

            $('#confirmDeleteModal .modal-body').html(
                `Sei sicuro di voler eliminare la provvigione per l'agente: <br><strong>${info}</strong>?`
            );

            var myModal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
            myModal.show();
        }

        /**
         * ESECUZIONE EFFETTIVA ELIMINAZIONE via AJAX
         */
        function eseguiEliminazione() {
            if (idDaEliminare === 0) return;

            $.post('@Url.Action("Delete", "ProvvigioniAgenti")', { id: idDaEliminare })
                .done(function (res) {
                    var modalEl = document.getElementById('confirmDeleteModal');
                    var modalInstance = bootstrap.Modal.getInstance(modalEl);
                    if(modalInstance) modalInstance.hide();

                    if (res.success) {
                        $('#provvigioniTable').DataTable()
                            .row(rigaDaRimuovere)
                            .remove()
                            .draw(false);

                        $('#modalOperazioneCompletata .modal-body').text("Configurazione provvigionale eliminata con successo.");
                        var successModal = new bootstrap.Modal(document.getElementById('modalOperazioneCompletata'));
                        successModal.show();
                    } else {
                        alert(res.message || "Errore durante l'eliminazione.");
                    }
                })
                .fail(function () {
                    alert("Errore tecnico nella comunicazione con il server.");
                })
                .always(function () {
                    idDaEliminare = 0;
                    rigaDaRimuovere = null;
                });
        }
    </script>
}