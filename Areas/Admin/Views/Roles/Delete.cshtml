@model IdentityRole

@{
    ViewData["Title"] = "Elimina Ruolo";
}

<div class="d-flex align-items-center mb-4">
    <i class="bi bi-trash-fill text-danger me-3" style="font-size: 2.5rem;"></i>
    <div>
        <h1 class="h3 fw-bold mb-0">Elimina Ruolo</h1>
        <small class="text-muted">Conferma l'eliminazione del ruolo</small>
    </div>
</div>

<div class="alert alert-danger">
    Sei sicuro di voler eliminare il ruolo <strong>@Model.Name</strong>?
</div>

<form method="post">
    <div class="d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Annulla
        </a>

        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Elimina
        </button>
    </div>
</form>
