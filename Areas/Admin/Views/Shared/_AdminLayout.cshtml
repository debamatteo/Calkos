@* @using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager *@

@using Calkos.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager



<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Calkos Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

    <style>
        body {
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: 200px;
            background-color: #ffffff;
            border-right: 1px solid #e5e5e5;
            padding: 20px 0;
            position: fixed;
            top: 0;
            bottom: 0;
        }
        /* 🔥 CAMPI READONLY IN GRIGIO */
        .input-readonly {
            background-color: #e9ecef !important;
            color: #6c757d !important;
            cursor: not-allowed;
        }
            .sidebar .logo-area {
                padding: 0 14px; /* stesso padding delle voci */
                display: flex;
                flex-direction: column;
                align-items: flex-start; /* allinea a sinistra come le voci */
                margin-bottom: 20px;
            }

                .sidebar .logo-area img {
                    height: 40px;
                    margin-bottom: 6px;
                }


            .sidebar .nav-link {
                color: #555;
                padding: 8px 14px;
                font-size: 0.85rem;
                display: flex;
                align-items: center;
                gap: 8px;
                margin: 4px 10px;
                border-radius: 6px;
                transition: background-color 0.2s ease;
            }

                .sidebar .nav-link:hover {
                    background-color: #f0f4ff;
                }

                .sidebar .nav-link.active {
                    background-color: #e7f1ff;
                    font-weight: 600;
                    color: #0d6efd;
                    border-left: 3px solid #0d6efd;
                }



        /* Main content */
        .main-content {
            margin-left: 200px;
            width: calc(100% - 200px);
        }

        /* Header */
        .admin-header {
            background-color: #ffffff;
            border-bottom: 1px solid #e5e5e5;
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .admin-header h1 {
                font-size: 1.4rem;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 10px;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo-area">
            <img src="~/img/logo.png" alt="Logo" />
            <div class="fw-bold">Calkos Admin</div>
        </div>



        <nav class="nav flex-column">

            @if (User.IsInRole("Admin"))
            {
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                     asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                   asp-area="Admin" asp-controller="Users" asp-action="Index">
                    <i class="bi bi-people"></i> Gestione Utenti
                </a>

                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Roles" ? "active" : "")"
                   asp-area="Admin" asp-controller="Roles" asp-action="Index">
                    <i class="bi bi-shield-lock"></i> Gestione Ruoli
                </a>

@*                 <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Roles" ? "active" : "")"
                   asp-area="Admin" asp-controller="Roles" asp-action="Index">
                    <i class="bi bi-shield-lock"></i> Gestione Anagrafiche
                </a> *@



            }


            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Prospetti" ? "active" : "")"
               asp-area="Admin" asp-controller="Prospetti" asp-action="Index">
                <i class="bi bi-table"></i> Gestione Prospetti
            </a>




        </nav>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <!-- HEADER -->
        <div class="admin-header">
            <div>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-light btn-sm border">
                    <i class="bi bi-house-door"></i> Home
                </a>
            </div>

            <div>
@*                 @if (SignInManager.IsSignedIn(User))
                {
                    <span class="me-3 text-muted">@User.Identity.Name</span>
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                } *@

                @if (SignInManager.IsSignedIn(User))
                {
                    <span class="me-3 text-muted">@User.Identity.Name</span>

                    <form asp-area="Identity"
                          asp-page="/Account/Logout"
                          method="post"
                          class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                }

            </div>
        </div>


        <!-- PAGE CONTENT -->
        <div class="p-4">
            @RenderBody()
        </div>

    </div>
    <!-- AGGIUNTO PER TEST SU DATATABLES C:\Lavoro\Calkos\Calkos.web\Areas\Admin\Views\Test\DataTables.cshtml-->
    <!-- ho dovuto remmare qui sotto e mettere bootstrap nelle view , altrimenti bootstrap non funzionava da nessuna parte -->
    @* <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script> *@

    @RenderSection("Scripts", required: false)

</body>
</html>



