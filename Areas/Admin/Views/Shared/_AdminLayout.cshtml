@using Calkos.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@* Antiforgery CENTRALIZZATO 05/04/2026  *@
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery  
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Calkos Admin</title>

    <!--
        LIBRERIE ESTERNE (CDN):
        - Bootstrap 5.3.2: Framework CSS per il layout responsive, griglie e componenti UI (pulsanti, modali).
        - Bootstrap Icons 1.11.1: Set di icone vettoriali utilizzate per i menu e i pulsanti d'azione.
    -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

    <!--
        FILE LOCALI E VERSIONAMENTO:
        - site.css: Stili personalizzati globali del progetto.
        - Calkos.web.styles.css: Isolamento CSS (CSS Isolation) generato da ASP.NET Core per i componenti.
        - asp-append-version="true": Carica una nuova versione del file se il contenuto cambia (evita problemi di cache).
    -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Calkos.web.styles.css" asp-append-version="true" />

    <style>
        /* --- LAYOUT GENERALE: Gestione dello spazio Sidebar + Contenuto --- */
        body {
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .main-content {
            margin-left: 200px; /* Spazio riservato alla sidebar fissa */
            width: calc(100% - 200px);
        }

        /* --- SIDEBAR: Menu di navigazione laterale fisso --- */
        .sidebar {
            width: 200px;
            background-color: #ffffff;
            border-right: 1px solid #e5e5e5;
            padding: 20px 0;
            position: fixed;
            top: 0;
            bottom: 0;
        }

            .sidebar .logo-area {
                padding: 0 14px;
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                margin-bottom: 20px;
            }

                .sidebar .logo-area img {
                    height: 40px;
                    margin-bottom: 6px;
                }

            /* Nav-link: Stile per le voci di menu e stati hover/active */
            .sidebar .nav-link {
                color: #555;
                padding: 8px 14px;
                font-size: 0.85rem;
                display: flex;
                align-items: center;
                gap: 8px;
                margin: 4px 10px;
                border-radius: 6px;
                transition: background-color 0.2s ease;
            }

                .sidebar .nav-link:hover {
                    background-color: #f0f4ff;
                }

                .sidebar .nav-link.active {
                    background-color: #e7f1ff;
                    font-weight: 600;
                    color: #0d6efd;
                    border-left: 3px solid #0d6efd;
                }

        /* --- HEADER: Barra superiore con pulsante Home e Info Utente --- */
        .admin-header {
            background-color: #ffffff;
            border-bottom: 1px solid #e5e5e5;
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* --- VALIDAZIONE: Stili per i messaggi di errore e campi obbligatori --- */
        .required-label::after {
            content: " *"; /* Aggiunge asterisco rosso ai label obbligatori */
            color: #dc3545;
            font-weight: bold;
            margin-left: 4px;
        }

        /* Evidenziazione bordo campo in caso di errore di validazione ASP.NET */
        .input-validation-error {
            border: 2px solid #dc3545 !important;
            background-color: #fff8f8 !important;
        }

        .input-readonly {
            background-color: #e9ecef !important;
            color: #6c757d !important;
            cursor: not-allowed;
        }

        .field-validation-error {
            color: #dc3545;
            font-size: 0.8rem;
            margin-top: 4px;
            display: block;
        }
    </style>
</head>

<body>
    <!-- Antiforgery CENTRALIZZATO 05/04/2026 -->
        @* Genera il token per le chiamate AJAX *@
        @{
            var tokens = Antiforgery.GetAndStoreTokens(Context);
        }
        <input type="hidden" id="RequestVerificationToken" name="RequestVerificationToken" value="@tokens.RequestToken" />

@*     <h1 style="color:red; background:yellow; position:fixed; top:0; z-index:9999;">LAYOUT ADMIN ATTIVO</h1> *@
    <!-- NAVIGAZIONE LATERALE CON CONTROLLO RUOLI -->
    <div class="sidebar">
        <div class="logo-area">
            <img src="~/img/logo.png" alt="Logo" />
            <div class="fw-bold">Calkos Admin</div>
        </div>

        <nav class="nav flex-column">
            @if (User.IsInRole("Admin"))
            {
                <!-- Sezione visibile solo agli Amministratori -->
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                   asp-area="Admin" asp-controller="Users" asp-action="Index">
                    <i class="bi bi-people"></i> Gestione Utenti
                </a>

                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Roles" ? "active" : "")"
                   asp-area="Admin" asp-controller="Roles" asp-action="Index">
                    <i class="bi bi-shield-lock"></i> Gestione Ruoli
                </a>

                <!-- Sotto-menu Anagrafiche (Toggle tramite JS) -->
                <div class="nav-link" style="cursor:pointer;" onclick="toggleAnagrafiche()">
                    <i class="bi bi-collection"></i> Gestione Anagrafiche
                    <i class="bi bi-caret-down-fill float-end" id="anagraficaArrow"></i>
                </div>

                <div id="anagraficheMenu" style="display:none; margin-left:20px;">
                    <a class="nav-link" asp-area="Admin" asp-controller="Agenti" asp-action="Index">• Agenti</a>
                    <a class="nav-link" asp-area="Admin" asp-controller="ProvvigioniAgenti" asp-action="Index">• Provvigioni</a>
                    <a class="nav-link" asp-area="Admin" asp-controller="Clienti" asp-action="Index">• Clienti</a>
                    <a class="nav-link" asp-area="Admin" asp-controller="Mandatari" asp-action="Index">• Mandatari</a>
                    <a class="nav-link" asp-area="Admin" asp-controller="Materiali" asp-action="Index">• Materiali</a>
                    <a class="nav-link" asp-area="Admin" asp-controller="MaterialiDimensioni" asp-action="Index">• Dimensioni</a>
                    <a class="nav-link" asp-area="Admin" asp-controller="TipoPagamento" asp-action="Index">• Pagamenti</a>
                    <a class="nav-link" asp-area="Admin" asp-controller="UnitaMisura" asp-action="Index">• Unità Misura</a>
                </div>
            }

            @if (User.IsInRole("Operatore") || User.IsInRole("Admin"))
            {
                <!-- Accesso alla gestione operativa per Admin e Operatori -->
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Prospetti" ? "active" : "")"
                   asp-area="Admin" asp-controller="Prospetti" asp-action="Index">
                    <i class="bi bi-table"></i> Gestione Prospetti
                </a>
            }
        </nav>
    </div>

    <!-- AREA CONTENUTO PRINCIPALE -->
    <div class="main-content">
        <header class="admin-header">
            <div>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-light btn-sm border">
                    <i class="bi bi-house-door"></i> Home
                </a>
            </div>
            <div>
                @if (SignInManager.IsSignedIn(User))
                {
                    <span class="me-3 text-muted">@User.Identity.Name</span>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                }
            </div>
        </header>

        <!-- RenderBody(): Placeholder dove viene iniettato il contenuto della View specifica -->
        <main role="main" class="p-4">
            @RenderBody()
        </main>
    </div>


    <!-- MODALI DI CONFERMA: Template riutilizzabili per eliminazione e reset dati -->
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Conferma eliminazione</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">Sei sicuro di voler eliminare questa riga?</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Elimina</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="confirmResetModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">Reset Fatturazione</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">Vuoi davvero resettare lo stato di fatturazione di questa riga?</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
                    <button id="confirmResetBtn" class="btn btn-info">Reset</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalOperazioneCompletata" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Operazione completata</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <!-- Testo dinamico inserito da ListaOrdini -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-bs-dismiss="modal">OK</button>
                </div>
            </div>
        </div>
    </div>


    <!--
        SCRIPTS LIBRERIE:
        - jQuery 3.7.1: Necessaria per manipolazione DOM, chiamate AJAX e gestione eventi.
        - Bootstrap JS Bundle: Include Popper.js, necessario per il corretto funzionamento di modali e dropdown.
    -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- RenderSectionAsync: Inserisce script specifici definiti nelle singole view -->
    @await RenderSectionAsync("Scripts", required: false)

    <!-- TOAST NOTIFICATION: Div nascosto per messaggi a centro schermo -->
    <div id="globalToast" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); background:#333; color:white; padding:20px 30px; border-radius:10px; font-size:1.2rem; z-index:99999; box-shadow:0 0 20px rgba(0,0,0,0.3); opacity:0; transition:opacity 0.4s ease;"></div>

    <script>

        // CONFIGURAZIONE ANTIFORGERY GLOBALE PER AJAX Antiforgery CENTRALIZZATO 05/04/2026
                $.ajaxSetup({
                    beforeSend: function (xhr) {
                        var token = $('#RequestVerificationToken').val();
                        if (token) {
                            xhr.setRequestHeader("RequestVerificationToken", token);
                        }
                    }
                });



        // Funzione per mostrare messaggi temporanei (Successi/Errori)
        function showToast(message) {
            var toast = $("#globalToast");
            toast.text(message);
            toast.css("display", "block");
            setTimeout(() => toast.css("opacity", "1"), 10);
            setTimeout(() => {
                toast.css("opacity", "0");
                setTimeout(() => toast.css("display", "none"), 400);
            }, 2500);
        }

        // Gestione apertura/chiusura menu Anagrafiche nella Sidebar
        function toggleAnagrafiche() {
            const menu = document.getElementById("anagraficheMenu");
            const arrow = document.getElementById("anagraficaArrow");
            if (menu.style.display === "none") {
                menu.style.display = "block";
                arrow.classList.replace("bi-caret-down-fill", "bi-caret-up-fill");
            } else {
                menu.style.display = "none";
                arrow.classList.replace("bi-caret-up-fill", "bi-caret-down-fill");
            }
        }
    </script>










</body>
</html>