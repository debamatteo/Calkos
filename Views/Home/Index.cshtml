@{
    ViewData["Title"] = "Benvenuto";
}

<div class="text-center mt-5">
    <h1 class="display-5 fw-bold">Benvenuto in Calkos</h1>
    <p class="lead text-muted">Sistema gestionale per il calcolo delle provvigioni.</p>

    @if (!User.Identity.IsAuthenticated)
    {
        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg mt-3">
            Accedi
        </a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary btn-lg mt-3">
            Vai alla tua area
        </a>
    }
</div>
