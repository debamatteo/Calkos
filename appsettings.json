{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "CalkosConnection": "Server=localhost;Database=Calkos;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "DebugOptions": {
    "ShowDeveloperErrors": true
  },

  "Importazione": {
    "ValoriFatturareTrue": [ "Sì", "Si", "OK", "1", "True" ]
  },
  "Percorsi": {
    "BackupCobral": "C:\\CalkosBackup\\Cobral"
  },

  "AllowedHosts": "*"
}


